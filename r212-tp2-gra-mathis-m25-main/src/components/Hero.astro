---
/* Hero.astro */
---
<section class="relative bg-[var(--color-bg-dark)] text-white pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden">
  
  <div class="grid-hybrid relative z-10">
    
    <div class="col-span-12 md:col-span-8">
      <h1 class="text-5xl md:text-8xl font-thin tracking-tighter leading-none mb-8">
        Crafting <span class="italic text-[var(--color-primary)]">Minimalist</span> <br />
        Living Spaces.
      </h1>
      
      <p class="text-lg md:text-xl text-[var(--color-text-muted)] max-w-md mb-12 font-light">
        TP3 Integration : Utilisation d'un système de grille fluide pour un rendu professionnel et adaptatif.
      </p>

      <div class="flex flex-wrap gap-6">
        <a href="#projects" class="px-8 py-4 bg-[var(--color-primary)] text-white uppercase text-xs tracking-widest font-bold hover:bg-white hover:text-black transition-all">
          View Projects
        </a>
        <a href="#contact" class="px-8 py-4 border border-white/20 text-white uppercase text-xs tracking-widest font-bold hover:bg-white/10 transition-all">
          Get in Touch
        </a>
      </div>
    </div>

    <div class="hidden md:flex md:col-span-4 items-end justify-end">
        <div class="w-full aspect-[3/4] border-l border-t border-white/10 p-8 flex flex-col justify-end italic text-sm text-white/40">
            <p>01 / Editorial Architecture</p>
            <p>Residential Design — 2026</p>
        </div>
    </div>
  </div>

  <div class="absolute right-0 top-0 w-1/3 h-full bg-[var(--color-primary)] opacity-5 pointer-events-none"></div>
</section>